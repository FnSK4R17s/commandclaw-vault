{
  "commitMessage": "vault backup: {{date}}",
  "autoCommitMessage": "vault backup: {{date}}",
  "commitDateFormat": "YYYY-MM-DD HH:mm:ss",
  "autoPush": true,
  "autoSaveInterval": 5,
  "autoPullInterval": 10,
  "autoPullOnBoot": true,
  "pullBeforePush": true,
